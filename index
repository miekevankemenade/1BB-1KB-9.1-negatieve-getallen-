                                                            <button
                                                                key={idx}
                                                                onClick={() => handleL4RemSelectToggle(idx)}
                                                                className={`p-5 rounded-2xl border text-2xl font-mono font-black transition-all ${btnStyle}`}
                                                            >
                                                                {opt.val}
                                                            </button>
                                                        );
                                                    })}
                                                </div>
                                            )}

                                            {/* Remediatie Type: Sequence Fill */}
                                            {(l4Questions[l4Step].remediation.type === 'sequence-fill' || l4Questions[l4Step].remediation.type === 'sequence-drop') && (
                                                <div className="flex flex-wrap items-center justify-center gap-3 py-6 bg-slate-950/60 rounded-2xl border border-slate-800 font-mono text-xl md:text-2xl font-bold">
                                                    {l4Questions[l4Step].remediation.sequence.map((num, idx) => (
                                                        <React.Fragment key={idx}>
                                                            <div className="px-4 py-3 text-slate-400 bg-slate-900/40 rounded-xl border border-slate-800">{num}</div>
                                                            <div className="text-slate-600">|</div>
                                                        </React.Fragment>
                                                    ))}

                                                    {l4RemInputs.map((val, idx) => (
                                                        <input
                                                            key={idx}
                                                            type="number"
                                                            value={val}
                                                            onChange={(e) => {
                                                                const updated = [...l4RemInputs];
                                                                updated[idx] = e.target.value;
                                                                setL4RemInputs(updated);
                                                            }}
                                                            placeholder="?"
                                                            className="w-16 h-16 text-center rounded-xl font-bold bg-slate-950 border-yellow-500/50 text-yellow-300 font-mono text-2xl"
                                                        />
                                                    ))}
                                                </div>
                                            )}

                                            {/* Remediatie Type: MCQ */}
                                            {(l4Questions[l4Step].remediation.type === 'opposite-match' || l4Questions[l4Step].remediation.type === 'thermometer-math') && (
                                                <div className="grid grid-cols-2 gap-3 max-w-md mx-auto">
                                                    {l4Questions[l4Step].remediation.options.map((opt, idx) => {
                                                        let btnStyle = l4RemSelectedOption === opt ? "border-yellow-500 bg-yellow-950/20 text-yellow-300 font-bold scale-[1.03]" : "border-slate-800 bg-slate-950/60 text-slate-300";

                                                        return (
                                                            <button
                                                                key={idx}
                                                                onClick={() => { playSynthSound('select'); setL4RemSelectedOption(opt); }}
                                                                className={`p-4 rounded-xl border text-lg font-bold transition-all ${btnStyle}`}
                                                            >
                                                                {opt}
                                                            </button>
                                                        );
                                                    })}
                                                </div>
                                            )}

                                            {l4RemChecked && (
                                                <div className={`mt-6 p-4 rounded-xl border text-center ${l4RemIsCorrect ? 'bg-emerald-950 text-emerald-400 border-emerald-500/30' : 'bg-rose-950 text-rose-400 border-rose-500/30'}`}>
                                                    {l4RemIsCorrect ? "Fantastisch hersteld! Klik hieronder om door te gaan naar de volgende vraag." : "Niet helemaal goed, let op de theorie!"}
                                                </div>
                                            )}

                                            <div className="mt-8 pt-4 border-t border-slate-800 flex justify-between">
                                                {l4RemChecked && l4RemIsCorrect ? (
                                                    <button
                                                        onClick={handleL4Next}
                                                        className="px-10 py-4 bg-gradient-to-r from-emerald-500 to-teal-500 text-white font-black rounded-xl hover:from-emerald-400 hover:to-teal-400 animate-bounce"
                                                    >
                                                        Ga door naar de volgende vraag!
                                                    </button>
                                                ) : (
                                                    <button 
                                                        onClick={checkL4AndRemediation} 
                                                        className="px-10 py-4 bg-yellow-500 text-slate-950 font-black rounded-xl hover:bg-yellow-400"
                                                    >
                                                        Controleer Herstelopgave
                                                    </button>
                                                )}
                                            </div>
                                        </div>
                                    </div>
                                )}

                                {/* Toets Eindschaal */}
                                {l4Step >= l4Questions.length && (
                                    <div className="text-center animate-in zoom-in-95 duration-300">
                                        <div className="bg-slate-900 border border-slate-800 rounded-[2.5rem] p-8 max-w-md mx-auto shadow-2xl relative overflow-hidden">
                                            <div className="absolute top-0 left-0 w-full h-2 bg-gradient-to-r from-emerald-500 to-teal-500"></div>
                                            
                                            {l4Score >= 3 ? (
                                                <div>
                                                    <div className="inline-flex items-center justify-center bg-emerald-500/20 text-emerald-400 p-6 rounded-full mb-6 ring-8 ring-emerald-500/10">
                                                        <Award size={64} className="animate-bounce" />
                                                    </div>
                                                    <h2 className="text-3xl font-black text-white mb-2">GESLAAGD!</h2>
                                                    <p className="text-emerald-400 font-bold text-lg mb-4">Eindscore: {l4Score} / {l4Questions.length}</p>
                                                    
                                                    <p className="text-slate-400 text-sm leading-relaxed mb-6">
                                                        Ongelooflijk goed gedaan! Door de extra adaptieve herstelvragen goed te maken, heb je bewezen dat je de wiskunde echt in de vingers hebt!
                                                    </p>

                                                    <div className="bg-slate-950 p-4 rounded-2xl border border-slate-800 mb-6">
                                                        <p className="text-xs text-yellow-400 font-bold uppercase tracking-widest mb-1">🎁 Toets Bonus</p>
                                                        <p className="text-lg font-black text-white">⭐ +250 XP Verdiend!</p>
                                                    </div>
                                                </div>
                                            ) : (
                                                <div>
                                                    <div className="inline-flex items-center justify-center bg-rose-500/20 text-rose-400 p-6 rounded-full mb-6 ring-8 ring-rose-500/10">
                                                        <RefreshCw size={64} />
                                                    </div>
                                                    <h2 className="text-3xl font-black text-white mb-2">PROBEER OPNIEUW</h2>
                                                    <p className="text-rose-400 font-bold text-lg mb-4">Score: {l4Score} / {l4Questions.length}</p>
                                                    
                                                    <p className="text-slate-400 text-sm leading-relaxed mb-6">
                                                        Net niet gehaald, zelfs met herstelpogingen! Ga rustig terug naar de levels om de basisvaardigheden nog even te herhalen.
                                                    </p>
                                                </div>
                                            )}

                                            <div className="flex flex-col gap-3">
                                                <button
                                                    onClick={restartL4}
                                                    className="w-full py-4 bg-gradient-to-r from-rose-500 to-pink-600 text-white font-black rounded-xl"
                                                >
                                                    Toets Opnieuw Doen
                                                </button>
                                                <button
                                                    onClick={() => { playSynthSound('click'); setView('theorie'); }}
                                                    className="w-full py-3 bg-slate-950 border border-slate-800 text-slate-400 font-bold rounded-xl hover:text-white"
                                                >
                                                    Terug naar theorie
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                )}
                            </div>
                        )}
                    </main>
                </div>
            );
        }

        // Render app
        const root = ReactDOM.createRoot(document.getElementById('root'));
        root.render(<App />);
    </script>
</body>
</html>
